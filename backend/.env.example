# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/fisherman_db

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# API Configuration
API_PORT=5000
API_HOST=0.0.0.0

# Weather API (optional - for external weather service)
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# SMS Configuration (for alerts)
SMS_PROVIDER=twilio
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=FishermanAlert
